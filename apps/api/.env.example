# API server
HOST=0.0.0.0
PORT=3333
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB
# Atlas: mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=database-name

# Superadmin seed (used on first run / migrations as applicable)
ADMIN_NAME=super-admin
ADMIN_EMAIL=super-admin@example.com
ADMIN_PASS=super-admin-password

#S3 Bucket Credentials
AWS_ACCESS_KEY_ID=access-key-id
AWS_SECRET_ACCESS_KEY=access-key-id
AWS_REGION=Region-name
AWS_S3_BUCKET_NAME=bucket-name

# SMTP (e.g. Gmail app password)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# CORS — comma-separated origins, no trailing slashes
FRONTEND_URL=http://localhost:4200
