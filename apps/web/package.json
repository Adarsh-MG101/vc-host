          "cwd": "apps/web",
          "command": "next dev --port 4200"
        }
      }
    }
  },
  "dependencies": {
    "next": "~16.0.1",
    "pizzip": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
